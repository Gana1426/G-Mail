# Application
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=MailHost Platform

# Database
DATABASE_URL=postgresql://mailhost:mailhost_secret@localhost:5432/mailhost?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Mail Server
# Mail Server (set MAIL_HOSTNAME to your real mail server hostname in production)
MAIL_HOSTNAME=mail.example.com
MAIL_SERVER_IP=127.0.0.1
MAIL_SMTP_PORT=587
MAIL_IMAP_PORT=993
MAIL_POP3_PORT=995
MAIL_DOMAIN=example.com
# Local dev: keep false to save sent mail to Maildir only (no Postfix required)
MAIL_SMTP_ENABLED=false
MAIL_IMAP_ENABLED=false

# Mail provisioning (maildirs + optional Postfix/Dovecot reload)
MAIL_DATA_PATH=./data/mail/vhosts
MAIL_RELOAD_ENABLED=false
POSTFIX_CONTAINER=mailhost-postfix-1
DOVECOT_CONTAINER=mailhost-dovecot-1

# PostfixAdmin
POSTFIXADMIN_DB_HOST=postgres
POSTFIXADMIN_DB_NAME=mailhost
POSTFIXADMIN_DB_USER=mailhost
POSTFIXADMIN_DB_PASSWORD=mailhost_secret

# Roundcube
ROUNDCUBE_URL=http://localhost:8080

# Razorpay (required for paid plans)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key!

# Transactional email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
ADMIN_EMAIL=
